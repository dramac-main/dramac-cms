{
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "functions": {
    "src/app/api/ai/**/*.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/invoicing/recurring/process",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/invoicing/overdue/check",
      "schedule": "0 7 * * *"
    }
  ]
}
